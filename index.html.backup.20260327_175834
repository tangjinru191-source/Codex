    <!-- Toast -->
    <div class="toast" id="toast"></div>

    <script>
        // Data Management
        const STORAGE_KEYS = {
            records: 'calorieTracker_records',
            exercises: 'calorieTracker_exercises',
            weights: 'calorieTracker_weights',
            settings: 'calorieTracker_settings'
        };

        let records = [];
        let exercises = [];
        let weights = [];
        let settings = { dailyGoal: 2000, targetWeight: null };
        let currentDate = new Date();
        let viewingDate = new Date();
        let currentMealType = 'breakfast';
        let selectedExerciseType = null;

        // Exercise type calorie rates (kcal per minute)
        const exerciseRates = {
            running: 10,
            walking: 4,
            cycling: 8,
            swimming: 12,
            yoga: 3,
            fitness: 6,
            basketball: 8,
            badminton: 7,
            other: 5
        };

        // Initialize
        function init() {
            loadData();
            loadSettings();
            renderToday();
            renderWeightView();
            renderCalendar();
            setupEventListeners();
        }

        function loadData() {
            const recordsData = localStorage.getItem(STORAGE_KEYS.records);
            const exercisesData = localStorage.getItem(STORAGE_KEYS.exercises);
            const weightsData = localStorage.getItem(STORAGE_KEYS.weights);

            if (recordsData) records = JSON.parse(recordsData);
            if (exercisesData) exercises = JSON.parse(exercisesData);
            if (weightsData) weights = JSON.parse(weightsData);
        }

        function saveData() {
            localStorage.setItem(STORAGE_KEYS.records, JSON.stringify(records));
            localStorage.setItem(STORAGE_KEYS.exercises, JSON.stringify(exercises));
            localStorage.setItem(STORAGE_KEYS.weights, JSON.stringify(weights));
        }

        function loadSettings() {
            const data = localStorage.getItem(STORAGE_KEYS.settings);
            if (data) {
                settings = { ...settings, ...JSON.parse(data) };
            }
            document.getElementById('daily-goal-input').value = settings.dailyGoal;
            if (settings.targetWeight) {
                document.getElementById('target-weight-input').value = settings.targetWeight;
            }
        }

        function saveSettings() {
            settings.dailyGoal = parseInt(document.getElementById('daily-goal-input').value) || 2000;
            localStorage.setItem(STORAGE_KEYS.settings, JSON.stringify(settings));
            renderToday();
            renderCalendar();
            showToast('设置已保存');
        }

        function saveTargetWeight() {
            const target = parseFloat(document.getElementById('target-weight-input').value);
            if (target && target > 0) {
                settings.targetWeight = target;
                localStorage.setItem(STORAGE_KEYS.settings, JSON.stringify(settings));
                renderWeightView();
                showToast('目标体重已保存');
            }
        }

        // Event Listeners
        function setupEventListeners() {
            // Navigation
            document.querySelectorAll('.nav-tab, .mobile-nav-item').forEach(el => {
                el.addEventListener('click', () => switchView(el.dataset.view));
            });

            // Food form
            document.getElementById('food-form').addEventListener('submit', handleFoodSubmit);

            // Exercise form
            document.getElementById('exercise-form').addEventListener('submit', handleExerciseSubmit);

            // Exercise type selection
            document.querySelectorAll('.exercise-type-option').forEach(option => {
                option.addEventListener('click', () => {
                    document.querySelectorAll('.exercise-type-option').forEach(o => o.classList.remove('selected'));
                    option.classList.add('selected');
                    selectedExerciseType = option.dataset.type;
                    calculateExerciseCalories();
                });
            });

            // Auto-calculate exercise calories
            document.getElementById('exercise-duration').addEventListener('input', calculateExerciseCalories);

            // Weight form
            document.getElementById('weight-form').addEventListener('submit', handleWeightSubmit);
        }

        function switchView(view) {
            document.querySelectorAll('.nav-tab, .mobile-nav-item').forEach(el => {
                el.classList.toggle('active', el.dataset.view === view);
            });
            document.querySelectorAll('.view').forEach(v => v.classList.add('hidden'));
            document.getElementById(`${view}-view`).classList.remove('hidden');

            if (view === 'calendar') renderCalendar();
            if (view === 'weight') renderWeightView();
        }

        // Calculate exercise calories
        function calculateExerciseCalories() {
            const duration = parseInt(document.getElementById('exercise-duration').value) || 0;
            let rate = 5; // default rate

            if (selectedExerciseType && exerciseRates[selectedExerciseType]) {
                rate = exerciseRates[selectedExerciseType];
            }

            const calories = Math.round(duration * rate);
            if (calories > 0) {
                document.getElementById('exercise-calories-input').value = calories;
            }
        }

        // Food Modal
        function openFoodModal(mealType, recordId = null) {
            currentMealType = mealType;
            document.getElementById('food-record-id').value = recordId || '';
            document.getElementById('food-modal-title').textContent = recordId ? '编辑食物' : '添加食物';

            if (recordId) {
                const record = records.find(r => r.id === recordId);
                if (record) {
                    document.getElementById('food-name').value = record.foodName;
                    document.getElementById('food-calories').value = record.calories;
                    document.getElementById('food-portion').value = record.portion || '';
                }
            } else {
                document.getElementById('food-form').reset();
            }

            document.getElementById('food-modal').classList.add('active');
        }

        function closeFoodModal() {
            document.getElementById('food-modal').classList.remove('active');
        }

        function handleFoodSubmit(e) {
            e.preventDefault();
            const recordId = document.getElementById('food-record-id').value;
            const recordData = {
                id: recordId || Date.now().toString(),
                date: formatDate(currentDate),
                mealType: currentMealType,
                foodName: document.getElementById('food-name').value,
                calories: parseInt(document.getElementById('food-calories').value) || 0,
                portion: document.getElementById('food-portion').value,
                createdAt: recordId ? (records.find(r => r.id === recordId)?.createdAt || Date.now()) : Date.now()
            };

            if (recordId) {
                const index = records.findIndex(r => r.id === recordId);
                if (index !== -1) records[index] = recordData;
                showToast('记录已更新');
            } else {
                records.push(recordData);
                showToast('记录已保存');
            }

            saveData();
            renderToday();
            renderCalendar();
            closeFoodModal();
        }

        // Exercise Modal
        function openExerciseModal(exerciseId = null) {
            document.getElementById('exercise-record-id').value = exerciseId || '';
            document.getElementById('exercise-modal-title').textContent = exerciseId ? '编辑运动' : '添加运动';

            if (exerciseId) {
                const exercise = exercises.find(e => e.id === exerciseId);
                if (exercise) {
                    document.getElementById('exercise-name').value = exercise.name;
                    document.getElementById('exercise-duration').value = exercise.duration;
                    document.getElementById('exercise-calories-input').value = exercise.calories;
                    selectedExerciseType = exercise.type;
                    document.querySelectorAll('.exercise-type-option').forEach(o => {
                        o.classList.toggle('selected', o.dataset.type === exercise.type);
                    });
                }
            } else {
                document.getElementById('exercise-form').reset();
                document.querySelectorAll('.exercise-type-option').forEach(o => o.classList.remove('selected'));
                selectedExerciseType = null;
            }

            document.getElementById('exercise-modal').classList.add('active');
        }

        function closeExerciseModal() {
            document.getElementById('exercise-modal').classList.remove('active');
        }

        function handleExerciseSubmit(e) {
            e.preventDefault();
            const exerciseId = document.getElementById('exercise-record-id').value;
            const exerciseData = {
                id: exerciseId || Date.now().toString(),
                date: formatDate(currentDate),
                type: selectedExerciseType || 'other',
                name: document.getElementById('exercise-name').value,
                duration: parseInt(document.getElementById('exercise-duration').value) || 0,
                calories: parseInt(document.getElementById('exercise-calories-input').value) || 0,
                createdAt: exerciseId ? (exercises.find(e => e.id === exerciseId)?.createdAt || Date.now()) : Date.now()
            };

            if (exerciseId) {
                const index = exercises.findIndex(e => e.id === exerciseId);
                if (index !== -1) exercises[index] = exerciseData;
                showToast('运动记录已更新');
            } else {
                exercises.push(exerciseData);
                showToast('运动记录已保存');
            }

            saveData();
            renderToday();
            renderCalendar();
            closeExerciseModal();
        }

        // Weight Modal
        function openWeightModal() {
            const todayWeight = weights.find(w => w.date === formatDate(currentDate));
            if (todayWeight) {
                document.getElementById('weight-input').value = todayWeight.weight;
                document.getElementById('weight-notes').value = todayWeight.notes || '';
            } else {
                document.getElementById('weight-form').reset();
            }
            document.getElementById('weight-modal').classList.add('active');
        }

        function closeWeightModal() {
            document.getElementById('weight-modal').classList.remove('active');
        }

        function handleWeightSubmit(e) {
            e.preventDefault();
            const weightValue = parseFloat(document.getElementById('weight-input').value);
            const notes = document.getElementById('weight-notes').value;
            const dateStr = formatDate(currentDate);

            const existingIndex = weights.findIndex(w => w.date === dateStr);
            const weightData = {
                date: dateStr,
                weight: weightValue,
                notes: notes,
                createdAt: existingIndex >= 0 ? weights[existingIndex].createdAt : Date.now()
            };

            if (existingIndex >= 0) {
                weights[existingIndex] = weightData;
                showToast('体重已更新');
            } else {
                weights.push(weightData);
                showToast('体重已记录');
            }

            saveData();
            renderToday();
            renderWeightView();
            closeWeightModal();
        }

        // Render Functions
        function renderToday() {
            const todayStr = formatDate(currentDate);
            const todayRecords = records.filter(r => r.date === todayStr);
            const todayExercises = exercises.filter(e => e.date === todayStr);

            // Calculate totals
            const mealTotals = { breakfast: 0, lunch: 0, dinner: 0, snack: 0 };
            let totalIntake = 0;
            todayRecords.forEach(r => {
                mealTotals[r.mealType] += r.calories;
                totalIntake += r.calories;
            });

            const totalExercise = todayExercises.reduce((sum, e) => sum + e.calories, 0);
            const netCalories = totalIntake - totalExercise;

            // Update quick stats
            document.getElementById('stat-intake').textContent = totalIntake;
            document.getElementById('stat-exercise').textContent = totalExercise;
            document.getElementById('stat-net').textContent = netCalories;

            // Update meal sections
            renderMealSection('breakfast', todayRecords.filter(r => r.mealType === 'breakfast'), mealTotals.breakfast);
            renderMealSection('lunch', todayRecords.filter(r => r.mealType === 'lunch'), mealTotals.lunch);
            renderMealSection('dinner', todayRecords.filter(r => r.mealType === 'dinner'), mealTotals.dinner);
            renderMealSection('snack', todayRecords.filter(r => r.mealType === 'snack'), mealTotals.snack);

            // Update exercise section
            renderExerciseSection(todayExercises, totalExercise);

            // Update weight card
            updateWeightCard();
        }

        function renderMealSection(mealType, mealRecords, total) {
            document.getElementById(`${mealType}-calories`).textContent = `${total} kcal`;
            const container = document.getElementById(`${mealType}-items`);

            if (mealRecords.length === 0) {
                container.innerHTML = `<div class="empty-item">点击 + 添加${getMealName(mealType)}记录</div>`;
                return;
            }

            container.innerHTML = mealRecords.map(record => `
                <div class="item" onclick="openFoodModal('${mealType}', '${record.id}')">
                    <div class="item-icon">🍽️</div>
                    <div class="item-info">
                        <div class="item-name">${record.foodName}</div>
                        <div class="item-detail">${record.portion || ''}</div>
                    </div>
                    <div class="item-calories">+${record.calories}</div>
                    <div class="item-actions" onclick="event.stopPropagation()">
                        <button class="item-edit" onclick="openFoodModal('${mealType}', '${record.id}')">✏️</button>
                        <button class="item-delete" onclick="deleteRecord('${record.id}')">🗑️</button>
                    </div>
                </div>
            `).join('');
        }

        function renderExerciseSection(todayExercises, total) {
            document.getElementById('exercise-calories').textContent = `-${total} kcal`;
            const container = document.getElementById('exercise-items');

            if (todayExercises.length === 0) {
                container.innerHTML = `<div class="empty-item">点击 + 添加运动记录</div>`;
                return;
            }

            container.innerHTML = todayExercises.map(exercise => `
                <div class="item exercise-item" onclick="openExerciseModal('${exercise.id}')">
                    <div class="item-icon">${getExerciseIcon(exercise.type)}</div>
                    <div class="item-info">
                        <div class="item-name">${exercise.name}</div>
                        <div class="item-detail">${exercise.duration} 分钟</div>
                    </div>
                    <div class="item-calories negative">-${exercise.calories}</div>
                    <div class="item-actions" onclick="event.stopPropagation()">
                        <button class="item-edit" onclick="openExerciseModal('${exercise.id}')">✏️</button>
                        <button class="item-delete" onclick="deleteExercise('${exercise.id}')">🗑️</button>
                    </div>
                </div>
            `).join('');
        }

        function renderWeightView() {
            updateWeightCard();
            renderWeightChart();
        }

        function updateWeightCard() {
            const todayWeight = weights.find(w => w.date === formatDate(currentDate));
            const latestWeight = weights.length > 0 ? weights[weights.length - 1] : null;
            const currentWeight = todayWeight || latestWeight;

            const weightValueEl = document.getElementById('current-weight');
            const weightTrendEl = document.getElementById('weight-trend');
            const weightViewValueEl = document.getElementById('weight-view-current');
            const weightViewTrendEl = document.getElementById('weight-view-trend');

            if (currentWeight) {
                weightValueEl.innerHTML = `${currentWeight.weight}<span class="unit">kg</span>`;
                weightViewValueEl.innerHTML = `${currentWeight.weight}<span class="unit">kg</span>`;

                // Calculate trend
                const trend = calculateWeightTrend();
                const trendText = trend > 0 ? `↑ ${trend.toFixed(1)}kg` : trend < 0 ? `↓ ${Math.abs(trend).toFixed(1)}kg` : '→ 持平';
                const trendHtml = `<span>${trendText}</span> 较7天前`;

                weightTrendEl.innerHTML = trendHtml;
                weightViewTrendEl.innerHTML = trendHtml;
            } else {
                weightValueEl.innerHTML = `--<span class="unit">kg</span>`;
                weightViewValueEl.innerHTML = `--<span class="unit">kg</span>`;
                weightTrendEl.textContent = '点击记录体重';
                weightViewTrendEl.textContent = '点击记录体重';
            }
        }

        function calculateWeightTrend() {
            if (weights.length < 2) return 0;
            const sorted = [...weights].sort((a, b) => new Date(a.date) - new Date(b.date));
            const latest = sorted[sorted.length - 1].weight;
            const weekAgo = sorted.find(w => {
                const daysDiff = (new Date(sorted[sorted.length - 1].date) - new Date(w.date)) / (1000 * 60 * 60 * 24);
                return daysDiff >= 6 && daysDiff <= 8;
            });
            return weekAgo ? latest - weekAgo.weight : 0;
        }

        function renderWeightChart() {
            const chartContainer = document.getElementById('weight-chart');
            const last7Days = weights
                .sort((a, b) => new Date(b.date) - new Date(a.date))
                .slice(0, 7)
                .reverse();

            if (last7Days.length === 0) {
                chartContainer.innerHTML = '<div class="empty-item">暂无体重数据</div>';
                return;
            }

            const maxWeight = Math.max(...last7Days.map(w => w.weight));
            const minWeight = Math.min(...last7Days.map(w => w.weight));
            const range = maxWeight - minWeight || 1;

            chartContainer.innerHTML = last7Days.map(w => {
                const height = ((w.weight - minWeight) / range * 80 + 20);
                const date = new Date(w.date);
                const label = `${date.getMonth() + 1}/${date.getDate()}`;
                return `
                    <div class="chart-bar-wrapper">
                        <div class="chart-value">${w.weight.toFixed(1)}</div>
                        <div class="chart-bar" style="height: ${height}px"></div>
                        <div class="chart-label">${label}</div>
                    </div>
                `;
            }).join('');
        }

        function renderCalendar() {
            const year = viewingDate.getFullYear();
            const month = viewingDate.getMonth();
            document.getElementById('calendar-title').textContent = `${year}年${month + 1}月`;

            const firstDay = new Date(year, month, 1);
            const lastDay = new Date(year, month + 1, 0);
            const daysInMonth = lastDay.getDate();
            const startPadding = firstDay.getDay();

            const calendarDays = document.getElementById('calendar-days');
            calendarDays.innerHTML = '';

            // Previous month padding
            for (let i = 0; i < startPadding; i++) {
                calendarDays.appendChild(createCalendarDay('', true));
            }

            // Current month days
            const todayStr = formatDate(new Date());
            for (let day = 1; day <= daysInMonth; day++) {
                const dateStr = formatDate(new Date(year, month, day));
                const dayRecords = records.filter(r => r.date === dateStr);
                const dayExercises = exercises.filter(e => e.date === dateStr);
                const totalIntake = dayRecords.reduce((sum, r) => sum + r.calories, 0);
                const totalExercise = dayExercises.reduce((sum, e) => sum + e.calories, 0);
                const netCalories = totalIntake - totalExercise;

                const isToday = dateStr === todayStr;
                calendarDays.appendChild(createCalendarDay(day, false, netCalories, totalExercise, isToday));
            }
        }

        function createCalendarDay(day, isOtherMonth, netCalories = 0, exercise = 0, isToday = false) {
            const div = document.createElement('div');
            div.className = 'calendar-day';

            if (isOtherMonth) {
                div.classList.add('other-month');
            } else {
                if (netCalories === 0 && exercise === 0) {
                    div.classList.add('no-data');
                } else {
                    const ratio = Math.abs(netCalories) / settings.dailyGoal;
                    if (netCalories < 0) div.classList.add('low');
                    else if (ratio <= 0.8) div.classList.add('low');
                    else if (ratio <= 1) div.classList.add('normal');
                    else if (ratio <= 1.2) div.classList.add('high');
                    else div.classList.add('excess');
                }
                if (isToday) div.classList.add('today');

                div.innerHTML = `
                    <span class="calendar-day-number">${day}</span>
                    ${netCalories !== 0 ? `<span class="calendar-day-calories">${netCalories}</span>` : ''}
                    ${exercise > 0 ? `<span class="calendar-day-exercise">-${exercise}</span>` : ''}
                `;

                div.onclick = () => {
                    currentDate = new Date(viewingDate.getFullYear(), viewingDate.getMonth(), day);
                    switchView('today');
                };
            }

            return div;
        }

        // Actions
        function deleteRecord(id) {
            if (confirm('确定要删除这条记录吗？')) {
                records = records.filter(r => r.id !== id);
                saveData();
                renderToday();
                renderCalendar();
                showToast('记录已删除');
            }
        }

        function deleteExercise(id) {
            if (confirm('确定要删除这条运动记录吗？')) {
                exercises = exercises.filter(e => e.id !== id);
                saveData();
                renderToday();
                renderCalendar();
                showToast('运动记录已删除');
            }
        }

        function changeMonth(delta) {
            viewingDate.setMonth(viewingDate.getMonth() + delta);
            renderCalendar();
        }

        function goToToday() {
            viewingDate = new Date();
            currentDate = new Date();
            renderCalendar();
            switchView('today');
        }

        function exportData() {
            const data = { records, exercises, weights, settings, exportDate: new Date().toISOString() };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `calorie-tracker-backup-${formatDate(new Date())}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('数据已导出');
        }

        function importDataFile(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => {
                try {
                    const imported = JSON.parse(e.target.result);
                    if (!imported || typeof imported !== 'object') throw new Error('数据格式不正确');

                    const { records: newRecords = [], exercises: newExercises = [], weights: newWeights = [], settings: newSettings = {} } = imported;

                    if (Array.isArray(newRecords)) records = [...records, ...newRecords];
                    if (Array.isArray(newExercises)) exercises = [...exercises, ...newExercises];
                    if (Array.isArray(newWeights)) weights = [...weights, ...newWeights];

                    if (newSettings && typeof newSettings === 'object') {
                        settings = { ...settings, ...newSettings };
                        localStorage.setItem(STORAGE_KEYS.settings, JSON.stringify(settings));
                    }

                    saveData();
                    renderToday();
                    renderWeightView();
                    renderCalendar();
                    showToast('数据已导入，已合并到当前记录');
                } catch (err) {
                    showToast('导入失败：文件格式不正确');
                    console.error(err);
                }
            };
            reader.readAsText(file);
            event.target.value = '';
        }

        function clearAllData() {
            if (confirm('确定要清空所有数据吗？此操作不可恢复！')) {
                records = [];
                exercises = [];
                weights = [];
                localStorage.removeItem(STORAGE_KEYS.records);
                localStorage.removeItem(STORAGE_KEYS.exercises);
                localStorage.removeItem(STORAGE_KEYS.weights);
                renderToday();
                renderWeightView();
                renderCalendar();
                showToast('所有数据已清空');
            }
        }

        // Utilities
        function formatDate(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function getMealName(type) {
            const names = { breakfast: '早餐', lunch: '午餐', dinner: '晚餐', snack: '加餐' };
            return names[type] || type;
        }

        function getExerciseIcon(type) {
            const icons = {
                running: '🏃', walking: '🚶', cycling: '🚴', swimming: '🏊',
                yoga: '🧘', fitness: '💪', basketball: '🏀', badminton: '🏸', other: '🎯'
            };
            return icons[type] || '🏃';
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2000);
        }

        // Start
        init();
    </script>
</body>
</html>
